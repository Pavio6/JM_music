# .env.development
# 开发环境使用的环境变量

# 接口请求地址，会设置到 axios 的 baseURL 参数上
VITE_APP_API_BASEURL = http://127.0.0.1:8082
# Socket 服务地址
VITE_APP_SOCKET_URL = ws://localhost:8082/ws
# 资源请求地址
VITE_APP_ASSETS_URL = http://127.0.0.1:8082
# 是否开启 mock 数据
VITE_APP_OPEN_MOCK = false
# mock 接口请求地址
VITE_APP_MOCK_URL = http://127.0.0.1:4523/m1/5856451-5542794-default